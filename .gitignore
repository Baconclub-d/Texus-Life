# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地环境变量与密钥
.env
.env.*
!.env.example

# 依赖目录：如果以后用了 npm / pnpm / yarn，会自动生成
node_modules/

# 构建产物：如果以后引入打包工具，通常会生成这些
dist/
build/
.cache/
.vite/
.next/
out/

# 编辑器本地配置
.vscode/
.idea/

# 临时文件
*.tmp
*.temp
*.bak
*.swp

# 压缩包和导出文件
*.zip
*.rar
*.7z